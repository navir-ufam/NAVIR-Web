# Servidor
PORT=3000
NODE_ENV=development

# Banco de dados
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=usuario_banco
DB_PASSWORD=senha_banco
DB_DATABASE=navir_dev

# O Prisma utiliza a DATABASE_URL construída com as credenciais acima
DATABASE_URL="postgresql://usuario_banco:senha_banco@localhost:5432/navir_dev?schema=public"

ADMIN_EMAIL=exemple@exemple.com
ADMIN_PASSWORD=exemple

# JWT
JWT_SECRET=super_secret_jwt_key_here
JWT_EXPIRATION=24h

# CORS
CORS_ORIGIN=http://localhost:5173